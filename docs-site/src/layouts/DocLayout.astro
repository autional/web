---
const { title = 'Autional Docs' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html><html lang="en">
<head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>{title}</title><link rel="canonical" href={canonical.href}/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
<slot name="head"/>
</head>
<body class="min-h-screen bg-white dark:bg-slate-950 text-neutral-900 dark:text-white antialiased flex">
  <aside class="w-64 shrink-0 border-r border-neutral-200 dark:border-neutral-800 p-6 hidden md:block">
    <a href="/" class="text-lg font-bold text-primary-600">Autional Docs</a>
    <nav class="mt-8 space-y-1 text-sm">
      <a href="/" class="block rounded px-3 py-2 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-slate-800">Quick Start</a>
      <a href="/deployment" class="block rounded px-3 py-2 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-slate-800">Deployment</a>
      <a href="/api" class="block rounded px-3 py-2 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-slate-800">API Reference</a>
      <a href="/sdk" class="block rounded px-3 py-2 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-slate-800">SDK</a>
    </nav>
  </aside>
  <main class="flex-1 p-8 max-w-4xl"><slot/></main>
</body></html>
