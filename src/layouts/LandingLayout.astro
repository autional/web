---
import ClientShell from '../components/ClientShell.tsx';
import CookieConsent from '../components/CookieConsent.tsx';
import '../styles/global.css';
export interface Props { title: string; description?: string; }
const { title, description = 'Autional — Enterprise Identity & Access Management' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title><meta name="description" content={description} />
  <link rel="canonical" href={canonical.href} /><link rel="icon" type="image/png" sizes="680x680" href="/favicon-master-blue-v7.png?v=7" /><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=7" /><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=7" /><link rel="shortcut icon" type="image/png" href="/favicon-32x32.png?v=7" /><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=7" /><link rel="manifest" href="/site.webmanifest?v=7" /><meta name="theme-color" content="#ffffff" />
  <meta property="og:title" content={title} /><meta property="og:description" content={description} />
  <meta property="og:url" content={canonical.href} /><meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" hreflang="en" href={canonical.href} />
  <link rel="alternate" hreflang="x-default" href={canonical.href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700;800&family=Noto+Serif+SC:wght@600;700&display=swap" rel="stylesheet" />
</head>
<body class="flex min-h-screen flex-col text-neutral-900 dark:text-white">
  <header class="sticky top-0 z-50 px-3 py-3 sm:px-6">
    <div class="relative mx-auto flex max-w-7xl items-center justify-between rounded-full border border-white/70 bg-white/80 px-4 py-3 shadow-soft backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/70 sm:px-6">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo-mark.svg" alt="Autional logo" class="h-10 w-10 object-contain drop-shadow-[0_8px_18px_rgba(0,49,83,0.18)]" />
        <div class="hidden sm:block">
          <div class="text-[1.9rem] font-extrabold tracking-[-0.04em] text-primary-900 dark:text-white">Autional</div>
        </div>
      </a>
      <nav class="hidden items-center gap-1 md:flex">
        <a href="/features" class="rounded-full px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-sky-50 hover:text-primary-700 dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white">Features</a>
        <a href="/sdk" class="rounded-full px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-sky-50 hover:text-primary-700 dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white">SDK</a>
        <a href="/pricing" class="rounded-full px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-sky-50 hover:text-primary-700 dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white">Pricing</a>
        <a href="/docs" class="rounded-full px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-sky-50 hover:text-primary-700 dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white">Docs</a>
        <a href="/blog" class="rounded-full px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-sky-50 hover:text-primary-700 dark:text-neutral-300 dark:hover:bg-white/10 dark:hover:text-white">Blog</a>
        <a href="https://auth.iam.tianv.com" class="brand-button-primary ml-3 px-5 py-2.5">Sign In</a>
      </nav>
      <ClientShell client:load />
    </div>
  </header>
  <main class="flex-1" id="main-content"><slot /></main>
  <footer class="mt-12 px-4 pb-6 sm:px-6">
    <div class="mx-auto max-w-7xl rounded-[32px] bg-primary-900 px-6 py-12 text-white shadow-brand sm:px-10">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-5">
        <div class="md:col-span-2">
          <a href="/" class="inline-flex items-center">
            <div class="text-[2rem] font-extrabold tracking-[-0.04em] text-white">Autional</div>
          </a>
          <p class="mt-5 max-w-sm text-sm leading-7 text-sky-100/82">AI-powered identity infrastructure for modern SaaS platforms. Authentication, SSO, passkey, tenant isolation, audit, and developer APIs in one coherent system.</p>
          <div class="mt-6 flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.18em] text-sky-100/70">
            <span class="rounded-full border border-white/10 px-3 py-1.5">Prussian Blue</span>
            <span class="rounded-full border border-white/10 px-3 py-1.5">Sky Blue</span>
            <span class="rounded-full border border-white/10 px-3 py-1.5 text-amber-300">Amber</span>
          </div>
        </div>
        <div><h3 class="text-sm font-semibold text-white">Platform</h3><ul class="mt-4 space-y-3">
          <li><a href="/features" class="text-sm text-sky-100/72 transition-colors hover:text-white">Features</a></li>
          <li><a href="/pricing" class="text-sm text-sky-100/72 transition-colors hover:text-white">Pricing</a></li>
          <li><a href="/compare" class="text-sm text-sky-100/72 transition-colors hover:text-white">Compare</a></li>
          <li><a href="/roadmap" class="text-sm text-sky-100/72 transition-colors hover:text-white">Roadmap</a></li>
        </ul></div>
        <div><h3 class="text-sm font-semibold text-white">Developers</h3><ul class="mt-4 space-y-3">
          <li><a href="/docs" class="text-sm text-sky-100/72 transition-colors hover:text-white">Documentation</a></li>
          <li><a href="/sdk" class="text-sm text-sky-100/72 transition-colors hover:text-white">SDK</a></li>
          <li><a href="https://docs.autional.com" class="text-sm text-sky-100/72 transition-colors hover:text-white">Docs Portal</a></li>
          <li><a href="https://developer.autional.com" class="text-sm text-sky-100/72 transition-colors hover:text-white">Dev Portal</a></li>
          <li><a href="https://auth.iam.tianv.com" class="text-sm text-sky-100/72 transition-colors hover:text-white">Sign In</a></li>
        </ul></div>
        <div><h3 class="text-sm font-semibold text-white">Apps</h3><ul class="mt-4 space-y-3">
          <li><a href="https://app.iam.tianv.com/admin" class="text-sm text-sky-100/72 transition-colors hover:text-white">Admin</a></li>
          <li><a href="https://user.iam.tianv.com" class="text-sm text-sky-100/72 transition-colors hover:text-white">User Portal</a></li>
          <li><a href="https://app.iam.tianv.com/developer" class="text-sm text-sky-100/72 transition-colors hover:text-white">API Keys</a></li>
          <li><a href="https://app.iam.tianv.com/security" class="text-sm text-sky-100/72 transition-colors hover:text-white">Security</a></li>
        </ul></div>
        <div><h3 class="text-sm font-semibold text-white">Company</h3><ul class="mt-4 space-y-3">
          <li><a href="/about" class="text-sm text-sky-100/72 transition-colors hover:text-white">About</a></li>
          <li><a href="/blog" class="text-sm text-sky-100/72 transition-colors hover:text-white">Blog</a></li>
          <li><a href="/contact" class="text-sm text-sky-100/72 transition-colors hover:text-white">Contact</a></li>
        </ul></div>
      </div>
      <div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-sky-100/68 sm:flex-row sm:items-center sm:justify-between">
        <p>&copy; 2026 Autional. All rights reserved.</p>
        <div class="flex flex-wrap gap-4">
          <a href="/privacy" class="transition-colors hover:text-white">Privacy</a>
          <a href="/terms" class="transition-colors hover:text-white">Terms</a>
          <a href="/trust" class="transition-colors hover:text-white">Trust</a>
        </div>
      </div>
    </div>
  </footer>
  <CookieConsent client:load />
</body></html>
