---
import Layout from '../layouts/LandingLayout.astro';
---
<Layout title="404 — Page Not Found | AuthMS" description="Page not found">
  <div class="flex min-h-[50vh] items-center justify-center px-4 py-20"><div class="text-center">
    <p class="text-8xl font-extrabold text-primary-600">404</p>
    <h1 class="mt-4 text-2xl font-bold sm:text-3xl">Page Not Found</h1>
    <p class="mt-4 text-neutral-500">The page you are looking for does not exist or has been moved.</p>
    <div class="mt-8 flex items-center justify-center gap-4">
      <a href="/" class="rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary-700">Go Home</a>
      <a href="/blog" class="rounded-lg border px-6 py-2.5 text-sm font-semibold hover:bg-neutral-50 dark:hover:bg-slate-900">Browse Blog</a>
    </div>
  </div></div>
</Layout>
