---
import Layout from '../layouts/LandingLayout.astro';
---
<Layout title="Contact — Autional" description="Get in touch with the Autional team." keywords="Autional, contact, sales, support, enterprise, identity">
  <section class="mx-auto max-w-3xl px-4 py-20 text-center">
    <h1 class="text-4xl font-bold sm:text-5xl">Contact Us</h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-neutral-500">Technical questions, business inquiries, or partnership opportunities — we'd love to hear from you.</p>
    <div class="mt-12 grid gap-8 sm:grid-cols-3 text-left">
      <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 p-6"><h3 class="font-semibold">Technical Support</h3><p class="mt-2 text-sm text-neutral-500">GitHub Issues · Community Discord</p><a href="https://github.com/autional/web/issues" class="mt-3 inline-block text-sm text-primary-600 hover:underline">Open an Issue →</a></div>
      <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 p-6"><h3 class="font-semibold">Business Inquiries</h3><p class="mt-2 text-sm text-neutral-500">Enterprise licensing, partnerships</p><a href="mailto:hello@autional.com" class="mt-3 inline-block text-sm text-primary-600 hover:underline">hello@autional.com</a></div>
      <div class="rounded-xl border border-neutral-200 dark:border-neutral-800 p-6"><h3 class="font-semibold">Documentation</h3><p class="mt-2 text-sm text-neutral-500">API docs, deployment guides</p><a href="/docs" class="mt-3 inline-block text-sm text-primary-600 hover:underline">View Docs →</a></div>
    </div>
  </section>
</Layout>
