---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/LandingLayout.astro';

const posts = await getCollection('blog', ({ data }) => data.status === 'verified');
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const [featured, ...rest] = sorted;

const categories = ['Tech','Architecture','Compliance','Product','Security','Project'];
---
<Layout title="Blog — Aotional" description="Technical articles on identity, security, compliance, and architecture.">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="text-center">
      <h1 class="text-4xl font-bold sm:text-5xl">Blog</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-600 dark:text-neutral-300">Identity, security, compliance &amp; architecture — by the Aotional team.</p>
    </div>

    <div class="mt-8 flex flex-wrap justify-center gap-2">
      <a href="/blog" class="rounded-full bg-primary-600 text-white px-4 py-1.5 text-sm font-medium">All</a>
      {categories.map(c => <a href={`/blog?cat=${c}`} class="rounded-full bg-neutral-100 dark:bg-slate-800 text-neutral-600 px-4 py-1.5 text-sm font-medium hover:bg-neutral-200 dark:hover:bg-slate-700">{c}</a>)}
    </div>

    {featured && (
      <div class="mt-12 overflow-hidden rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-slate-900 shadow-sm">
        <div class="grid lg:grid-cols-2">
          <div class="flex items-center justify-center bg-primary-50 p-10 dark:bg-primary-900/10">
            <div class="text-center">
              <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary-100 text-primary-600"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg></div>
              <p class="mt-4 text-sm text-neutral-400">Featured</p>
            </div>
          </div>
          <div class="flex flex-col justify-center p-8 lg:p-10">
            <span class="inline-block w-fit rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">{featured.data.category}</span>
            <h2 class="mt-4 text-2xl font-bold"><a href={`/blog/${featured.id.replace(/\.md$/,'')}`} class="hover:text-primary-600">{featured.data.title}</a></h2>
            <p class="mt-3 text-neutral-600">{featured.data.excerpt}</p>
            <div class="mt-4 flex items-center gap-4 text-sm text-neutral-500"><span>{featured.data.date}</span><span>{featured.data.readTime}</span></div>
            <div class="mt-6"><a href={`/blog/${featured.id.replace(/\.md$/,'')}`} class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700">Read more <span class="text-lg">&rarr;</span></a></div>
          </div>
        </div>
      </div>
    )}

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map(post => {
        const slug = post.id.replace(/\.md$/,'');
        return (
          <article class="group flex flex-col rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-slate-900 p-6 shadow-sm hover:shadow-md transition-all">
            <span class="rounded-full bg-primary-50 dark:bg-primary-900/30 px-2.5 py-0.5 text-xs font-medium text-primary-700 w-fit">{post.data.category}</span>
            <a href={`/blog/${slug}`} class="mt-4"><h3 class="text-lg font-semibold group-hover:text-primary-600">{post.data.title}</h3></a>
            <p class="mt-2 flex-1 text-sm text-neutral-600 dark:text-neutral-400">{post.data.excerpt}</p>
            <div class="mt-4 flex flex-wrap gap-2">{post.data.tags.map(tag => <span class="text-xs text-neutral-400">#{tag}</span>)}</div>
            <div class="mt-4 flex items-center gap-4 border-t border-neutral-100 pt-4 text-xs text-neutral-500"><span>{post.data.date}</span><span>{post.data.readTime}</span></div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>
